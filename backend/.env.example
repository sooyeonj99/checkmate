# ── 데이터베이스 ───────────────────────────────────────────
# PostgreSQL 미사용 시 주석 처리 가능
# DATABASE_URL=postgresql://postgres:password@localhost:5432/checkmate

# ── 보안 ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS (프론트엔드 출처) ────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://sooyeonj99.github.io"]

# ── 파일 업로드 ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── Gemini AI (계약서 분석) ───────────────────────────────
# Google AI Studio (aistudio.google.com) 에서 발급 (무료)
GEMINI_API_KEY=your-gemini-api-key-here

# ── 이메일 (SMTP) ─────────────────────────────────────────
# Gmail: 구글 계정 → 보안 → 2단계 인증 → 앱 비밀번호 발급
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
FRONTEND_URL=http://localhost:3000/checkmate

# ── 개인정보 마스킹 (Presidio + spaCy) ──────────────────
# 설치: bash install_models.sh
# 수동:
#   pip install presidio-analyzer presidio-anonymizer spacy
#   python -m spacy download en_core_web_sm    (필수)
#   python -m spacy download ko_core_news_sm   (선택 - 이름/기관명 감지 향상)
