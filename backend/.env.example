# ── 데이터베이스 ───────────────────────────────────────────
# PostgreSQL 미사용 시 주석 처리 가능
# DATABASE_URL=postgresql://postgres:password@localhost:5432/checkmate

# ── 보안 ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS (프론트엔드 출처) ────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://sooyeonj99.github.io"]

# ── 파일 업로드 ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── Gemini AI (계약서 분석) ───────────────────────────────
# Google AI Studio (aistudio.google.com) 에서 발급
GEMINI_API_KEY=your-gemini-api-key-here
